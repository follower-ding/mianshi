# =============================================================================
# mianshi 生产环境 .env 填表示例
# =============================================================================
# 用法（在服务器上）：
#   cd /opt/mianshi/deploy
#   cp .env.sample .env
#   nano .env          # 把下面「请替换」项改成你的真实值
#
# ⚠️ 本文件仅为示例，可提交 Git；真实 .env 永远不要 commit
# 详细说明：docs/09-发布上线/SERVER-DEPLOY-GUIDE.md §5
# =============================================================================

# --- PostgreSQL（Docker 内置数据库）-------------------------------------------
# 作用：启动 postgres 容器 + API 的 DATABASE_URL 自动拼接
POSTGRES_USER=mianshi
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=mianshi

# --- 用户认证 -----------------------------------------------------------------
# JWT_SECRET：登录 Token 签名密钥，泄露可伪造任意用户
JWT_SECRET=change-me-jwt-secret-min-32-chars

# 首次启动自动创建的管理员（登录 /admin）
ADMIN_EMAIL=admin@mianshi.local
ADMIN_PASSWORD=admin123456

# --- 大模型（DeepSeek 示例）--------------------------------------------------
# 不填 LLM_API_KEY → 自动 Demo 降级（可演示，非真实 AI）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- 跨域与端口 ---------------------------------------------------------------
# CORS_ORIGIN 必须与用户浏览器地址栏一致（协议+域名/IP+端口）
#
# 场景 A：仅 IP 访问（无域名，80 端口可直接 http://IP 访问）
CORS_ORIGIN=http://49.235.172.214
#
# 场景 B：有域名 + HTTPS（推荐，取消下行注释并删掉上面 IP 那行）
# CORS_ORIGIN=https://mianshi.example.com
#
# 场景 C：域名 + 本地开发联调（逗号分隔，无空格）
# CORS_ORIGIN=https://mianshi.example.com,http://localhost:5174

# 宿主机映射端口（安全组/防火墙需放行 WEB_PORT）
API_PORT=8788
WEB_PORT=80    # 用户访问：http://49.235.172.214（安全组放行 80/TCP）

# --- 可选 ---------------------------------------------------------------------
# 豆包语音合成（火山引擎）https://console.volcengine.com/speech/new/setting/apikeys
TTS_API_KEY=

# Boss 智能投递 Worker 内部通信（部署 mianshi-worker 时再填）
WORKER_INTERNAL_KEY=wk_mianshi_internal_7f3a9c2e1b8d4f6a

# =============================================================================
# 配置完成后启动：
#   docker compose -f docker-compose.prod.yml up -d --build
# 验收：
#   curl -sf http://127.0.0.1:8788/api/health
#   curl -sf -o /dev/null -w "%{http_code}\n" http://127.0.0.1:8080/
# =============================================================================

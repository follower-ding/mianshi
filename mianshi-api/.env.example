# DeepSeek（OpenAI 兼容）— 密钥无效时简历导入/优化自动降级为演示模式
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# LLM_FORCE_DEMO=1

PORT=8788
# 多个域名用逗号分隔，如 https://mianshi.netlify.app,http://localhost:5174
CORS_ORIGIN=http://localhost:5174
# Serverless 预览域（可选）
# ALLOW_NETLIFY_PREVIEWS=1
# ALLOW_VERCEL_PREVIEWS=1

# PostgreSQL（Phase 3 平台化，docker compose up -d 后启用）
DATABASE_URL=postgresql://mianshi:mianshi@localhost:5432/mianshi

# 用户认证
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@mianshi.local
ADMIN_PASSWORD=admin123456

# LLM Gateway
LLM_CACHE_TTL_MS=3600000

# 豆包语音合成（火山引擎）https://console.volcengine.com/speech/new/setting/apikeys
TTS_API_KEY=
# TTS_API_BASE=openspeech.bytedance.com
# TTS_RESOURCE_ID=seed-tts-2.0

# Boss Worker（Python 持久化 + 定时打工）
WORKER_ENABLED=false
WORKER_URL=http://localhost:8790
WORKER_INTERNAL_KEY=change-me-worker-key
BOSS_PROFILE_ROOT=../mianshi-worker/storage/profiles
BOSS_CONNECT_ROOT=../mianshi-worker/storage/connect
# REBIND_WEBHOOK_URL=
# REBIND_WEBHOOK_ENABLED=false

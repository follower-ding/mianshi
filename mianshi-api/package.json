    "mammoth": "^1.12.0",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.1.200",
    "playwright": "^1.52.0",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }

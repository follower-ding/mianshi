{
  "name": "mianshi-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "quality:regression": "tsx scripts/quality-regression.ts",
    "test:resume-demo": "tsx scripts/resume-demo-regression.ts",
    "test:import-extract": "tsx scripts/resume-import-extract.ts",
    "test:resume-share": "tsx scripts/resume-share-regression.ts",
    "test:resume-file-guard": "tsx scripts/resume-file-guard.test.ts",
    "test:smart-import-batch": "tsx scripts/smart-import-batch.test.ts",
    "test:quiz-score": "tsx scripts/quiz-score.test.ts",
    "test:resume-field-coverage": "tsx scripts/resume-field-coverage.test.ts",
    "migrate:json-resumes": "tsx scripts/migrate-json-resumes-to-pg.ts",
    "verify:pg-resumes": "tsx scripts/verify-pg-resumes.ts",
    "test:resume-all": "npm run test:resume-demo && npm run test:import-extract && npm run test:resume-share && npm run test:resume-file-guard",

{
  "name": "mianshi-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:bundles": "node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:export": "tsx scripts/test-resume-export.ts",
    "test:templates": "tsx scripts/resume-templates-check.ts",
    "test:resume-all": "npm run test:export && npm run test:templates",
    "test:e2e:resume": "playwright test e2e/resume-export.spec.ts e2e/resume-import-wizard.spec.ts e2e/resume-crud.spec.ts e2e/resume-extended-modules.spec.ts e2e/resume-share.spec.ts",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "html2canvas-pro": "^2.2.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "remark-gfm": "^4.0.1"
  }
}

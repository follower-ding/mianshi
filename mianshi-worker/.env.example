# PostgreSQL（与 mianshi-api 相同）
DATABASE_URL=postgresql://mianshi:mianshi@localhost:5432/mianshi

# Profile 根目录（与 Node BOSS_PROFILE_ROOT 保持一致）
BOSS_PROFILE_ROOT=../mianshi-worker/storage/profiles

# Headless 浏览器
BOSS_HEADLESS=true

# mianshi-api 内部回调（Worker 触发 Node 侧 AI 打分/入库）
MIANSHI_API_URL=http://localhost:8788
WORKER_INTERNAL_KEY=change-me-worker-key

# NEED_REBIND Webhook（Slack/飞书/Discord 等）
REBIND_WEBHOOK_URL=
REBIND_WEBHOOK_ENABLED=false

# 调度器时区
SCHEDULER_TZ=Asia/Shanghai

# FastAPI 健康检查端口
WORKER_HTTP_PORT=8790
